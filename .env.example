# Public browser variables (must be NEXT_PUBLIC_*)
NEXT_PUBLIC_APP_NAME=RiverX Next Template
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Runtime mode and server binding
NEXT_DEV=true
PORT=3000
HEALTHCHECK_PATH=/

# Git bootstrap/poll orchestration
GIT_BOOTSTRAP=false
GIT_POLL=true
GIT_POLL_INTERVAL=2000
PREVIEW_BRANCH=main
REPO_URL=

# Optional DB/runtime parity vars (not required for frontend-only template)
DATABASE_URL=
DB_MIGRATE_RETRY_MS=3000
DB_MIGRATE_CONNECT_TIMEOUT_SEC=10
PGCONNECT_TIMEOUT=10
DATABASE_SSL=false
